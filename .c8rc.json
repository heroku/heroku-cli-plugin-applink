{
  "all": true,
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist/**/*",
    "**/*.test.ts",
    "test/**/*",
    "**/*types.ts",
    "node_modules/**/*",
    "src/commands/**/*",
    "src/lib/jwtAuthCommand.ts",
    "src/index.ts"
  ],
  "reporter": ["text", "html", "lcov", "text-summary"],
  "clean": true,
  "temp-directory": "./coverage/tmp",
  "report-dir": "./coverage",
  "check-coverage": true,
  "statements": 80,
  "branches": 70,
  "functions": 80,
  "lines": 80
}
