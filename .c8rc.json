{
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.d.ts",
    "**/*.test.ts",
    "test/**/*",
    "dist/**/*",
    "src/index.ts",
    "src/lib/types.ts"
  ],
  "extension": [".ts"],
  "reporter": ["text", "text-summary", "html", "lcov"],
  "check-coverage": true,
  "statements": 80,
  "branches": 80,
  "functions": 80,
  "lines": 80
}
